{
    "name": "@skipq/api",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "bun run --watch src/index.ts",
        "build": "bun build src/index.ts --outdir ./dist --target bun",
        "test": "bun test",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:seed": "bun run src/db/seed.ts",
        "db:studio": "drizzle-kit studio"
    },
    "dependencies": {
        "@skipq/shared": "workspace:*",
        "elysia": "^1.4.0",
        "@elysiajs/cors": "^1.2.0",
        "@elysiajs/bearer": "^1.2.0",
        "drizzle-orm": "^0.39.0",
        "postgres": "^3.4.0",
        "ioredis": "^5.4.0",
        "bullmq": "^5.30.0",
        "better-auth": "^1.2.0",
        "nanoid": "^5.0.0"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "drizzle-kit": "^0.30.0",
        "typescript": "^5.7.0"
    }
}